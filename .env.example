# Cloudflare API (used by both GCP and Oracle deployments)
CF_TOKEN=your_cloudflare_api_token
CF_EMAIL=your_email@example.com

# DDNS records JSON — A records for Oracle, AAAA records for GCP
# Must be single-line when used in terraform.tfvars (systemd EnvironmentFile constraint)
DDNS_RECORDS_JSON='[
  {"name":"headscale.example.com","zone":"ZONE_ID","record":"RECORD_ID"}
]'

# ─── Oracle Cloud (terraform/oracle/) ────────────────────────────────────────
# Copy these into terraform/oracle/terraform.tfvars (without TF_VAR_ prefix)

# OCI API authentication (~/.oci/config values)
TF_VAR_tenancy_ocid=ocid1.tenancy.oc1..your_tenancy
TF_VAR_user_ocid=ocid1.user.oc1..your_user
TF_VAR_fingerprint=aa:bb:cc:dd:ee:ff:00:11:22:33:44:55:66:77:88:99
TF_VAR_private_key_path=~/.oci/oci_api_key.pem
TF_VAR_region=us-phoenix-1
TF_VAR_compartment_id=ocid1.compartment.oc1..your_compartment

# Instance
TF_VAR_ssh_public_key=ssh-ed25519 AAAA...
TF_VAR_vm_name=headscale-node
TF_VAR_ocpus=1
TF_VAR_memory_gb=6

# DDNS (must be single-line JSON for systemd EnvironmentFile)
TF_VAR_cf_token=your_cloudflare_api_token
TF_VAR_cf_email=your_email@example.com
TF_VAR_ddns_records_json=[{"name":"headscale.example.com","zone":"ZONE_ID","record":"RECORD_ID"}]

# Cloudflare R2 — Litestream SQLite replication (survive instance destroy/recreate)
# Create bucket: shortcircuit-headscale, then create an R2 API token with Object Read & Write
TF_VAR_r2_access_key_id=your_r2_access_key_id
TF_VAR_r2_secret_access_key=your_r2_secret_access_key
TF_VAR_r2_endpoint=https://ACCOUNT_ID.r2.cloudflarestorage.com
TF_VAR_r2_bucket=shortcircuit-headscale

# Headscale
TF_VAR_headscale_server_url=https://headscale.example.com
TF_VAR_headscale_version=0.25.1
