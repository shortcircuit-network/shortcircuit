# Cloudflare API
CF_TOKEN=your_cloudflare_api_token
CF_EMAIL=your_email@example.com

# DDNS record configuration (JSON string for multiple records)
# Example: [{"name":"jkubo.github.io","zone":"ZONEID","record":"RECORDID"}]
DDNS_RECORDS_JSON='[
  {"name":"jkubo.github.io","zone":"ZZZZ_IO","record":"RRRR_IO"},
  {"name":"jkubo.github.xyz","zone":"ZZZZ_XYZ","record":"RRRR_XYZ"}
]'

# Logging / State
LOG_PATH=./logs/ddns.log
STATE_PATH=./state/ip.txt

# Update interval in minutes (systemd timer overrides)
UPDATE_INTERVAL=5
TTL=120
PROXIED=false
